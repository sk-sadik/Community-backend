				{
					"name": "Login User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.environment.set(\"TOKEN\", jsonData.token);",
									"    console.log(\"Saved User JWT Token to Environment: \" + jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
